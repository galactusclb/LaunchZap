model User {
  id            String   @id @default(cuid())
  name      String   @unique
  email         String
  emailVerified Boolean @default(false)
  createdAt     DateTime
  updatedAt     DateTime
  role          Roles @default(USER)

  products Product[]
  votes    Vote[]

  @@unique([email])
  @@map("users")
}

enum Roles {
  ADMIN
  USER
}
